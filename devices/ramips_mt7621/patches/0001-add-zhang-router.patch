From: OpenWrt Custom
Date: Now
Subject: add ZHANG_ROUTER MT7621 device

--- /dev/null
+++ b/target/linux/ramips/dts/mt7621_zhang_router.dts
@@ -0,0 +1,222 @@
+#include "mt7621.dtsi"
+
+#include <dt-bindings/gpio/gpio.h>
+#include <dt-bindings/input/input.h>
+
+/ {
+	compatible = "zhang,router", "mediatek,mt7621-soc";
+	model = "ZHANG ROUTER";
+
+	aliases {
+		led-boot = &led_blue;
+		led-failsafe = &led_blue;
+		led-running = &led_blue;
+		led-upgrade = &led_blue;
+	};
+	chosen {
+		bootargs = "console=ttyS0,115200";
+	};
+   
+	leds {
+		compatible = "gpio-leds";
+
+		stat_r {
+			label = "red:status";
+			gpios = <&gpio 16 GPIO_ACTIVE_HIGH>;
+		};
+
+		stat_y {
+			label = "yellow:status";
+			gpios = <&gpio 17 GPIO_ACTIVE_LOW>;
+		};
+
+		led_blue: stat_b {
+			label = "blue:status";
+			gpios = <&gpio 18 GPIO_ACTIVE_LOW>;
+		};
+		led_power:power {
+			label = "power:status";
+			gpios = <&gpio 13 GPIO_ACTIVE_LOW>;
+		};
+        esw_led0: esw_led0 {
+        label = "ESW_P1_LED_0";
+        gpios = <&gpio 5 GPIO_ACTIVE_HIGH>;
+        default-state = "off";
+		};
+ 
+
+	}; 
+  
+	keys {
+		compatible = "gpio-keys";
+
+		reset {
+			label = "reset";
+			 gpios = <&gpio 16 GPIO_ACTIVE_LOW>;   /*RT-85B*/
+			/*gpios = <&gpio 3 GPIO_ACTIVE_LOW>;  */ /*小米4A*/
+			linux,code = <KEY_RESTART>;
+		};
+	};
+};
+
+&spi0 {
+	status = "okay";
+
+	flash@0 {
+		compatible = "jedec,spi-nor";
+		reg = <0>;
+		spi-max-frequency = <50000000>;
+
+		partitions {
+			compatible = "fixed-partitions";
+			#address-cells = <1>;
+			#size-cells = <1>;
+
+			partition@0 {
+				label = "u-boot";
+				reg = <0x0 0x30000>;
+				//read-only;
+			};
+
+			partition@30000 {
+				label = "u-boot-env";
+				reg = <0x30000 0x10000>;
+				//read-only;
+			};
+
+			factory: partition@40000 {
+				label = "factory";
+				reg = <0x40000 0x10000>;
+			//	read-only;
+			};
+
+			partition@50000 {
+				label = "permanent_config";
+				reg = <0x50000 0x50000>;
+				//read-only;
+			};
+
+			partition@a0000 {
+				compatible = "denx,uimage";
+				label = "firmware";
+				reg = <0xa0000 0xf60000>;
+			};
+		};
+	};
+};
+
+&pcie {
+	status = "okay";
+};
+&pcie0 {
+	wifi@0,0 {
+		compatible = "mediatek,mt76";
+		reg = <0x0000 0 0 0 0>;
+		mediatek,mtd-eeprom = <&factory 0x0>;		
+	};
+};
+
+&pcie1 {
+	wifi@0,0 {
+		compatible = "mediatek,mt76";
+		reg = <0x0000 0 0 0 0>;
+		mediatek,mtd-eeprom = <&factory 0x8000>;
+
+		/* 5 GHz (phy1) does not take the address from calibration data,
+		   but setting it manually here works */
+		nvmem-cells = <&macaddr_factory_4>;
+		nvmem-cell-names = "mac-address";
+	};
+};
+&pcie2 {
+	status = "disabled";
+};
+
+&switch0 {
+	ports {
+		port@4 {
+			status = "okay";
+			label = "lan4";
+		};
+	
+		port@1 {
+			status = "okay";
+			label = "lan1";
+		};
+
+		port@2 {
+			status = "okay";
+			label = "lan2";
+		};
+
+		port@3 {
+			status = "okay";
+			label = "lan3";
+		};	
+		port@0 {
+			status = "okay";
+			label = "wan";
+		};	  
+	};
+};
+
+&gpio {
+	gpio7_default_low {
+		gpio-hog;
+		gpios = <7 GPIO_ACTIVE_HIGH>;
+		output-low;
+		line-name = "gpio7-default-low";
+	};
+};
+
+&state_default {
+	gpio {
+		groups = "i2c", "jtag";
+		function = "gpio";
+	};
+};
+
+&factory {
+	compatible = "nvmem-cells";
+	#address-cells = <1>;
+	#size-cells = <1>;
+
+	macaddr_factory_4: macaddr@4 {
+		reg = <0x4 0x6>;
+	};
+
+	macaddr_factory_e000: macaddr@e000 {
+		reg = <0xe000 0x6>;
+	};
+
+	macaddr_factory_e006: macaddr@e006 {
+		reg = <0xe006 0x6>;
+	};
+};
+
--- a/target/linux/ramips/image/mt7621.mk
+++ b/target/linux/ramips/image/mt7621.mk
@@ -4000,0 +4000,13 @@
+define Device/zhang_router
+  DEVICE_DTS := mt7621_zhang_router
+  DEVICE_VENDOR := ZHANG
+  DEVICE_MODEL := ROUTER
+  DEVICE_TITLE := ZHANG ROUTER MT7621
+  KERNEL := $(KERNEL_DTB) | uImage lzma
+  KERNEL_INITRAMFS := $(KERNEL_DTB) | uImage lzma
+  IMAGE_SIZE := 16064k
+  IMAGES := sysupgrade.bin factory.bin
+  DEVICE_PACKAGES := kmod-mt7621
+endef
+TARGET_DEVICES += zhang_router