From: OpenWrt Custom
Date: Now
Subject: add ZHANG_ROUTER MT7621 device

--- /dev/null
+++ b/target/linux/ramips/dts/mt7621_zhang_router.dts
@@ -0,0 +1,118 @@
+#include "mt7621.dtsi"
+
+#include <dt-bindings/gpio/gpio.h>
+#include <dt-bindings/input/input.h>
+
+/ {
+	model = "ZHANG ROUTER";
+	compatible = "zhang,router", "mediatek,mt7621-soc";
+
+	chosen {
+		bootargs = "console=ttyS0,115200n8";
+	};
+
+	gpio-leds {
+		compatible = "gpio-leds";
+
+		gpio7_ctrl {
+			label = "gpio7";
+			gpios = <&gpio 7 GPIO_ACTIVE_HIGH>;
+			default-state = "off";
+		};
+	};
+
+	gpio-keys {
+		compatible = "gpio-keys";
+
+		flip_gpio7 {
+			label = "flip-gpio7";
+			gpios = <&gpio 8 GPIO_ACTIVE_LOW>;
+			linux,code = <BTN_0>;
+			debounce-interval = <60>;
+		};
+
+		rfkill {
+			label = "rfkill";
+			gpios = <&gpio 14 GPIO_ACTIVE_LOW>;
+			linux,code = <KEY_WLAN>;
+			debounce-interval = <60>;
+		};
+
+		wps {
+			label = "wps";
+			gpios = <&gpio 12 GPIO_ACTIVE_LOW>;
+			linux,code = <KEY_WPS_BUTTON>;
+			debounce-interval = <60>;
+		};
+
+		reset {
+			label = "reset";
+			gpios = <&gpio 16 GPIO_ACTIVE_LOW>;
+			linux,code = <KEY_RESTART>;
+			debounce-interval = <60>;
+			wakeup-source;
+		};
+	};
+};
+
+&state_default {
+	gpio {
+		groups = "gpio";
+		function = "gpio";
+	};
+};
+
+&pcie {
+	status = "okay";
+};
+
+&pcie0 {
+	wifi@0,0 {
+		reg = <0x0000 0 0 0 0>;
+		mediatek,mtd-eeprom = <&factory 0x0000>;
+	};
+};
+
+&pcie1 {
+	wifi@0,0 {
+		reg = <0x0000 0 0 0 0>;
+		mediatek,mtd-eeprom = <&factory 0x8000>;
+	};
+};
+
+&gmac0 {
+	status = "okay";
+};
+
+&switch0 {
+	ports {
+		port@3 { status = "okay"; label = "lan3"; };
+		port@2 { status = "okay"; label = "lan2"; };
+		port@1 { status = "okay"; label = "lan1"; };
+		port@0 { status = "okay"; label = "wan"; };
+		port@4 { status = "okay"; label = "lan4"; };
+	};
+};
+
+&gnss { status = "disabled"; };
+&nand { status = "disabled"; };
+
+&spi0 {
+	status = "okay";
+
+	flash@0 {
+		compatible = "jedec,spi-nor";
+		reg = <0>;
+		spi-max-frequency = <10000000>;
+
+		partitions {
+			compatible = "fixed-partitions";
+			#address-cells = <1>;
+			#size-cells = <1>;
+
+			partition@0 { label = "u-boot"; reg = <0x0 0x30000>; read-only; };
+			partition@30000 { label = "u-boot-env"; reg = <0x30000 0x10000>; read-only; };
+			factory: partition@40000 { label = "factory"; reg = <0x40000 0x10000>; read-only; };
+			partition@50000 { compatible = "denx,uimage"; label = "firmware"; reg = <0x50000 0xfb0000>; };
+		};
+	};
+};
+
+&uart0 { status = "okay"; };
--- a/target/linux/ramips/image/mt7621.mk
+++ b/target/linux/ramips/image/mt7621.mk
@@ -0,0 +1,14 @@
+define Device/zhang_router
+  DEVICE_DTS := mt7621_zhang_router
+  DEVICE_VENDOR := ZHANG
+  DEVICE_MODEL := ROUTER
+  DEVICE_TITLE := ZHANG ROUTER MT7621
+  KERNEL := $(KERNEL_DTB) | uImage lzma
+  KERNEL_INITRAMFS := $(KERNEL_DTB) | uImage lzma
+  IMAGE_SIZE := 16064k
+  IMAGES := sysupgrade.bin factory.bin
+  DEVICE_PACKAGES := kmod-mt7621
+endef
+TARGET_DEVICES += zhang_router
+
